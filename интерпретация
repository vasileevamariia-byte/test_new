      const navB = document.querySelector('.navigation-buttons');
      if (navB) navB.style.display = 'none';
      const pb = document.getElementById('progress-bar-container');
      if (pb) pb.style.display = 'none';
      const idx = frames.findIndex(f => f.id === 'result-screen');
      if (idx === -1) return;
      currentFrameIndex = idx;
      frames.forEach(f => f.style.display = 'none');
      frames[idx].style.display = 'block';
      const resB = document.querySelector('.result-buttons');
      if (resB) resB.style.display = 'flex';
      try { displayResults(); } catch (e) { console.error('displayResults:', e); }
      try { sendDataToGoogleSheet(); } catch (e) { console.error('sendData:', e); }
      setTimeout(() => { try { generateAndSavePDF(); } catch (e) { console.error('genPDF:', e); } }, 1500);
    } catch (e) { console.error('finishTest fatal:', e); }
