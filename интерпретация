const SCRIPT_URL = "https://script.google.com/macros/s/AKfycbzsQvgL-Zl-dRMDWc4bx3c-5W214aPXeVqE7fqPp8gNI7S4-qVzSVFtY_F3Qigsx_Ve/exec";

// ============== СОСТОЯНИЕ ==============
let partnerCount = 0;
let partnerNames = [];
let answers = {};              // { qN: { partnerIdx: 'yes'|'no'|'unknown'|'na' } }
let frames, totalQuestions = 121;
let currentFrameIndex = 0;
let cameFromIncompleteSummary = false;
const userData = {};

(function __boot() {
  // Запускаемся и при обычной загрузке, и если DOM уже готов (важно при подключении
  // скрипта внешним файлом через <script src> на Тильде).
  if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', __boot); return; }
  function init() {
    frames = Array.from(document.querySelectorAll('.frame'));
    setupQuestionMeta();
    setupFormValidation();
    setupPartnersConfig();
    // Обработчики кнопок ответа навешиваются прямо при их создании
    // в injectAnswerRowsIntoAllQuestions — делегация не нужна.
    showFrame(currentFrameIndex);
    document.getElementById('prevButton').addEventListener('click', prevFrame);
    document.getElementById('nextButton').addEventListener('click', nextFrame);
    document.getElementById('resetButton').addEventListener('click', () => window.location.reload());
    const welcomeBtn = document.getElementById('welcomeNextBtn');
    if (welcomeBtn) welcomeBtn.addEventListener('click', nextFrame);
    setupOptionalSurvey();
  }

  function setupOptionalSurvey() {
    const opt = document.getElementById('optional-survey');
    if (!opt) return;
    opt.querySelectorAll('.opt-pills').forEach(group => {
      group.addEventListener('click', e => {
        const btn = e.target.closest('.opt-pill');
        if (!btn) return;
        const wasSelected = btn.classList.contains('selected');
        group.querySelectorAll('.opt-pill').forEach(b => b.classList.remove('selected'));
        if (!wasSelected) btn.classList.add('selected');
      });
    });
    const collect = () => {
      opt.querySelectorAll('.opt-pills').forEach(group => {
        const name = group.getAttribute('data-opt-name');
        const sel = group.querySelector('.opt-pill.selected');
        if (sel && name) userData[name] = sel.getAttribute('data-value');
      });
    };
    document.getElementById('optionalSkipBtn').addEventListener('click', () => { finishTest(); });
    document.getElementById('optionalSubmitBtn').addEventListener('click', () => { collect(); finishTest(); });
  }

  function setupQuestionMeta() {
    document.querySelectorAll('.question').forEach((q, i) => {
      const cat = q.getAttribute('data-scale');
      const sub = q.getAttribute('data-subscale');
      const m = q.querySelector('.q-meta');
      m.textContent = '';
    });
  }

  function setupFormValidation() {
    const fc = document.getElementById('form-container');
    if (!fc) return;
    fc.querySelectorAll('input').forEach(inp => inp.addEventListener('input', checkFormValidity));
  }
  function checkFormValidity() {
    const name = document.getElementById('user-name').value.trim();
    const emailEl = document.getElementById('user-email');
    const email = emailEl.value.trim();
    const ok = document.getElementById('privacy-agree').checked && name && email && emailEl.checkValidity();
    const nb = document.getElementById('nextButton');
    if (ok) { nb.classList.remove('button-disabled'); nb.disabled = false; }
    else { nb.classList.add('button-disabled'); nb.disabled = true; }
  }

  // ============== ПАРТНЁРЫ ==============
  function setupPartnersConfig() {
    const btns = document.querySelectorAll('.partner-count-btn');
    btns.forEach(b => b.addEventListener('click', () => {
      btns.forEach(x => x.classList.remove('selected'));
      b.classList.add('selected');
      partnerCount = parseInt(b.getAttribute('data-count'), 10);
      renderPartnerNameInputs(partnerCount);
      checkPartnersValidity();
    }));
  }
  function renderPartnerNameInputs(count) {
    const prompt = document.getElementById('partner-names-prompt');
    const list = document.getElementById('partner-names-list');
    list.innerHTML = '';
    prompt.style.display = 'block';
    for (let i = 0; i < count; i++) {
      const row = document.createElement('div');
      row.className = 'partner-name-row';
      row.innerHTML = '<label>Партнёр ' + (i + 1) + '</label><input type="text" class="partner-name-input" data-partner-idx="' + i + '" placeholder="Имя">';
      list.appendChild(row);
    }
    list.querySelectorAll('.partner-name-input').forEach(inp => inp.addEventListener('input', checkPartnersValidity));
  }
  function checkPartnersValidity() {
    const inputs = document.querySelectorAll('.partner-name-input');
    let allFilled = partnerCount > 0 && inputs.length === partnerCount;
    inputs.forEach(inp => { if (!inp.value.trim()) allFilled = false; });
    const nb = document.getElementById('nextButton');
    if (allFilled) { nb.classList.remove('button-disabled'); nb.disabled = false; }
    else { nb.classList.add('button-disabled'); nb.disabled = true; }
  }
  function commitPartners() {
    partnerNames = [];
    document.querySelectorAll('.partner-name-input').forEach(inp => partnerNames.push(inp.value.trim()));
    injectAnswerRowsIntoAllQuestions();
  }

  // Создаёт строки ответов в каждом вопросе и сразу навешивает прямые
  // обработчики на кнопки — не зависим от document-level делегации.
  function injectAnswerRowsIntoAllQuestions() {
    document.querySelectorAll('.question').forEach(q => {
      const qId = q.getAttribute('data-q-id');
      const wrap = q.querySelector('.partner-rows');
      wrap.innerHTML = '';
      for (let pi = 0; pi < partnerCount; pi++) {
        const row = document.createElement('div');
        row.className = 'partner-row';
        const labelHtml = partnerCount > 1
          ? '<div class="partner-row-label">' + escapeHtml(partnerNames[pi]) + '<span class="check" style="display:none;">✓ отмечено</span></div>'
          : '';
        row.innerHTML = labelHtml +
          '<div class="ans-buttons">' +
            '<button type="button" class="ans-btn" data-type="yes" data-p="' + pi + '" data-q="' + qId + '">Да</button>' +
            '<button type="button" class="ans-btn" data-type="no" data-p="' + pi + '" data-q="' + qId + '">Нет</button>' +
            '<button type="button" class="ans-btn" data-type="unknown" data-p="' + pi + '" data-q="' + qId + '">Не уверен(а)</button>' +
          '</div>' +
          '<div class="not-applicable-wrap">' +
            '<button type="button" class="not-applicable" data-p="' + pi + '" data-q="' + qId + '">не релевантно</button>' +
          '</div>';
        wrap.appendChild(row);
        // Прямые слушатели на кнопках ответа.
        row.querySelectorAll('.ans-btn').forEach(b => {
          b.addEventListener('click', () => recordAnswer(b, b.getAttribute('data-type')));
        });
        row.querySelectorAll('.not-applicable').forEach(b => {
          b.addEventListener('click', () => recordAnswer(b, 'na'));
        });
      }
      if (partnerCount > 1) {
        const bw = document.createElement('div');
        bw.className = 'bulk-apply-wrap';
        bw.innerHTML = '<button type="button" class="bulk-apply" data-q="' + qId + '">Применить ответ ко всем партнёрам</button>';
        wrap.appendChild(bw);
        bw.querySelector('.bulk-apply').addEventListener('click', () => onBulkApply(qId));
      }
    });
  }

  function recordAnswer(btn, type) {
    try {
      const qid = btn.getAttribute('data-q');
      const piAttr = btn.getAttribute('data-p');
      if (!qid || piAttr === null) return;
      const pi = parseInt(piAttr, 10);
      if (isNaN(pi)) return;
      const row = btn.closest('.partner-row');
      if (!row) return;
      row.querySelectorAll('.ans-btn').forEach(b => b.classList.remove('selected'));
      row.querySelectorAll('.not-applicable').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      if (!answers[qid]) answers[qid] = {};
      answers[qid][pi] = type;
      const check = row.querySelector('.check');
      if (check) check.style.display = 'inline';
      updateProgress();
      if (isQuestionComplete(qid)) {
        updateButtonsVisibility(currentFrameIndex);
        // Маленькая задержка только для визуальной обратной связи —
        // юзер успевает увидеть, какую кнопку он нажал.
        setTimeout(autoAdvanceOrFinish, 180);
      }
    } catch (e) { console.error('recordAnswer error:', e); }
  }

  function autoAdvanceOrFinish() {
    if (cameFromIncompleteSummary) {
      const nextIdx = findNextIncompleteFrameIndex(currentFrameIndex);
      if (nextIdx !== -1) { currentFrameIndex = nextIdx; showFrame(nextIdx); return; }
      cameFromIncompleteSummary = false;
      if (countCompletedQuestions() === totalQuestions) { showOptionalSurveyOrFinish(); return; }
      showIncompleteSummary();
      return;
    }
    for (let i = currentFrameIndex + 1; i < frames.length; i++) {
      const q = frames[i].querySelector('.question');
      if (q) { currentFrameIndex = i; showFrame(i); return; }
    }
    if (countCompletedQuestions() === totalQuestions) { showOptionalSurveyOrFinish(); return; }
    showIncompleteSummary();
  }

  function findNextIncompleteFrameIndex(fromIdx) {
    const tryFind = (start, end) => {
      for (let i = start; i < end; i++) {
        const q = frames[i].querySelector('.question');
        if (q && !isQuestionComplete(q.getAttribute('data-q-id'))) return i;
      }
      return -1;
    };
    let f = tryFind(fromIdx + 1, frames.length);
    if (f !== -1) return f;
    return tryFind(0, fromIdx);
  }

  let optionalSurveyShown = false;
  function showOptionalSurveyOrFinish() {
    const opt = document.getElementById('optional-survey');
    if (!opt || optionalSurveyShown) { finishTest(); return; }
    optionalSurveyShown = true;
    frames = Array.from(document.querySelectorAll('.frame'));
    const idx = frames.indexOf(opt);
    if (idx === -1) { finishTest(); return; }
    cameFromIncompleteSummary = false;
    const navB = document.querySelector('.navigation-buttons');
    if (navB) navB.style.display = 'none';
    const pb = document.getElementById('progress-bar-container');
    if (pb) pb.style.display = 'none';
    currentFrameIndex = idx;
    showFrame(idx);
  }

  function showIncompleteSummary() {
    cameFromIncompleteSummary = false;
    const navB = document.querySelector('.navigation-buttons');
    if (navB) navB.style.display = 'none';
    const pb = document.getElementById('progress-bar-container');
    if (pb) pb.style.display = 'none';
    let summaryFrame = document.getElementById('incomplete-summary');
    if (!summaryFrame) {
      summaryFrame = document.createElement('section');
      summaryFrame.className = 'frame'; summaryFrame.id = 'incomplete-summary';
      const optScreen = document.getElementById('optional-survey');
      optScreen.parentNode.insertBefore(summaryFrame, optScreen);
      frames = Array.from(document.querySelectorAll('.frame'));
    }
    const incomplete = [];
    document.querySelectorAll('.question').forEach((q, idx) => {
      const qid = q.getAttribute('data-q-id');
      if (!isQuestionComplete(qid)) {
        const scale = q.getAttribute('data-scale');
        const sub = q.getAttribute('data-subscale');
        const statement = q.querySelector('.h2Survey')?.textContent || '';
        const frameIdx = frames.indexOf(q.closest('.frame'));
        incomplete.push({ idx: idx + 1, frameIdx, scale, sub, statement });
      }
    });
    let listHtml = '';
    incomplete.forEach(it => {
      listHtml += '<li class="incomplete-item" data-frame-idx="' + it.frameIdx + '">' +
        '<span class="incomplete-num">' + it.idx + ' / ' + totalQuestions + '</span>' +
        '<span class="incomplete-meta">' + it.scale + ' · ' + it.sub + '</span>' +
        '<span class="incomplete-text">' + it.statement + '</span>' +
        '<span class="incomplete-arrow">→</span></li>';
    });
    summaryFrame.innerHTML =
      '<span class="eyebrow">Шаг 4 из 4</span>' +
      '<h1 class="h1Survey">Осталось закрыть несколько вопросов</h1>' +
      '<p class="pSurvey muted">Ниже — утверждения, по которым ' + (partnerCount > 1 ? 'не хватает ответа хотя бы для одного из партнёров' : 'нет ответа') + '. Нажмите на пункт, чтобы перейти к нему.</p>' +
      '<ul class="incomplete-list">' + listHtml + '</ul>' +
      '<div style="display:flex;justify-content:space-between;gap:16px;margin-top:24px;flex-wrap:wrap;">' +
        '<button type="button" id="finishAnywayBtn" class="ghost-btn">Завершить без них</button>' +
        '<button type="button" id="goFirstIncompleteBtn" class="primary-btn">Перейти к первому →</button>' +
      '</div>';
    summaryFrame.querySelectorAll('.incomplete-item').forEach(li => {
      li.addEventListener('click', () => {
        const fi = parseInt(li.getAttribute('data-frame-idx'), 10);
        if (!isNaN(fi)) { cameFromIncompleteSummary = true; currentFrameIndex = fi; showFrame(fi);
          if (navB) navB.style.display = 'flex'; if (pb) pb.style.display = 'block'; }
      });
    });
    summaryFrame.querySelector('#goFirstIncompleteBtn').addEventListener('click', () => {
      if (incomplete.length) {
        cameFromIncompleteSummary = true;
        currentFrameIndex = incomplete[0].frameIdx;
        showFrame(currentFrameIndex);
        if (navB) navB.style.display = 'flex';
        if (pb) pb.style.display = 'block';
      }
    });
    summaryFrame.querySelector('#finishAnywayBtn').addEventListener('click', () => {
      cameFromIncompleteSummary = false;
      showOptionalSurveyOrFinish();
    });
    frames.forEach(f => f.style.display = 'none');
    summaryFrame.style.display = 'block';
    currentFrameIndex = frames.indexOf(summaryFrame);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function onBulkApply(qid) {
    const q = document.querySelector('.question[data-q-id="' + qid + '"]');
    const firstAns = q.querySelector('.ans-btn.selected, .not-applicable.selected');
    if (!firstAns) { alert('Сначала выберите ответ для первого партнёра — он будет применён ко всем.'); return; }
    const isNa = firstAns.classList.contains('not-applicable');
    const type = isNa ? 'na' : firstAns.getAttribute('data-type');
    for (let pi = 0; pi < partnerCount; pi++) {
      const row = q.querySelectorAll('.partner-row')[pi];
      row.querySelectorAll('.ans-btn').forEach(b => b.classList.remove('selected'));
      row.querySelectorAll('.not-applicable').forEach(b => b.classList.remove('selected'));
      let btn = isNa ? row.querySelector('.not-applicable') : row.querySelector('.ans-btn[data-type="' + type + '"]');
      if (btn) btn.classList.add('selected');
      if (!answers[qid]) answers[qid] = {};
      answers[qid][pi] = type;
      const check = row.querySelector('.check');
      if (check) check.style.display = 'inline';
    }
    updateProgress();
    if (isQuestionComplete(qid)) {
      updateButtonsVisibility(currentFrameIndex);
      if (countCompletedQuestions() === totalQuestions) showOptionalSurveyOrFinish();
      else setTimeout(autoAdvanceOrFinish, 250);
    }
  }
  function isQuestionComplete(qid) {
    if (!answers[qid]) return false;
    return Object.keys(answers[qid]).length === partnerCount;
  }
  function countCompletedQuestions() {
    let c = 0;
    document.querySelectorAll('.question').forEach(q => {
      if (isQuestionComplete(q.getAttribute('data-q-id'))) c++;
    });
    return c;
  }
  function updateProgress() {
    const pct = Math.round((countCompletedQuestions() / totalQuestions) * 100);
    const fill = document.getElementById('progress-bar-fill');
    if (fill) fill.style.width = pct + '%';
  }
  function escapeHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

  // ============== НАВИГАЦИЯ ==============
  function showFrame(index) {
    frames.forEach((f, i) => f.style.display = i === index ? 'block' : 'none');
    const cur = frames[index];
    updateButtonsVisibility(index);
    const isQ = !!cur.querySelector('.question');
    document.getElementById('progress-bar-container').style.display = isQ ? 'block' : 'none';
    if (isQ) updateProgress();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
  function updateButtonsVisibility(index) {
    const prev = document.getElementById('prevButton');
    const next = document.getElementById('nextButton');
    const cur = frames[index];
    const isWelcome = !!cur.querySelector('.Hello');
    const isForm = !!cur.querySelector('#form-container');
    const isPartners = !!cur.querySelector('#partners-config');
    const isInstr = !!cur.querySelector('.instruction');
    const isQ = !!cur.querySelector('.question');
    const isResult = cur.id === 'result-screen';
    const isLoad = cur.id === 'loading-screen';
    const isOpt = cur.id === 'optional-survey';
    const navContainer = document.querySelector('.navigation-buttons');
    const resultC = document.querySelector('.result-buttons');
    navContainer.style.display = (isResult || isLoad || isWelcome || isOpt) ? 'none' : 'flex';
    resultC.style.display = isResult ? 'flex' : 'none';
    prev.style.display = isWelcome ? 'none' : 'block';
    if (isWelcome) { next.style.display = 'none'; }
    else if (isForm) { next.style.display = 'block'; next.textContent = 'К партнёрам →'; checkFormValidity(); }
    else if (isPartners) { next.style.display = 'block'; next.textContent = 'К инструкции →'; checkPartnersValidity(); }
    else if (isInstr) { next.style.display = 'block'; next.textContent = 'Начать тест →'; next.disabled = false; next.classList.remove('button-disabled'); }
    else if (isQ) {
      const qid = cur.querySelector('.question').getAttribute('data-q-id');
      if (isQuestionComplete(qid)) {
        next.style.display = 'block'; next.textContent = 'Далее →';
        next.disabled = false; next.classList.remove('button-disabled');
      } else { next.style.display = 'none'; }
    } else { next.style.display = 'none'; }
  }
  function nextFrame() {
    if (frames[currentFrameIndex].querySelector('#form-container')) {
      userData.name = document.getElementById('user-name').value;
      userData.email = document.getElementById('user-email').value;
    }
    if (frames[currentFrameIndex].querySelector('#partners-config')) {
      commitPartners();
    }
    if (currentFrameIndex < frames.length - 1) {
      const nextIdx = currentFrameIndex + 1;
      if (frames[nextIdx] && frames[nextIdx].id === 'loading-screen') {
        if (countCompletedQuestions() === totalQuestions) showOptionalSurveyOrFinish();
        else autoAdvanceOrFinish();
        return;
      }
      currentFrameIndex = nextIdx;
      showFrame(currentFrameIndex);
    }
  }
  function prevFrame() { if (currentFrameIndex > 0) { currentFrameIndex--; showFrame(currentFrameIndex); } }

  // ============== ПОДСЧЁТ ==============
  function computeResults() {
    // perPartner[pi] = { cat: { score, blindspot, allNa, subs[], layer, icon, totals } }
    const perPartner = [];
    for (let pi = 0; pi < partnerCount; pi++) {
      const subTotals = {};
      for (const cat in scaleStructure) {
        subTotals[cat] = {};
        scaleStructure[cat].subscales.forEach(s => subTotals[cat][s] = { yes:0, no:0, unknown:0, na:0, total:0 });
      }
      for (let i = 0; i < qMetaByIdx.length; i++) {
        const qid = 'q' + (i + 1);
        const meta = qMetaByIdx[i];
        const a = answers[qid] && answers[qid][pi];
        if (!a || !subTotals[meta.scale] || !subTotals[meta.scale][meta.subscale]) continue;
        const b = subTotals[meta.scale][meta.subscale];
        b.total++;
        if (a === 'yes') b.yes++;
        else if (a === 'no') b.no++;
        else if (a === 'unknown') b.unknown++;
        else if (a === 'na') b.na++;
      }
      const catRes = {};
      for (const cat in subTotals) {
        const subs = subTotals[cat];
        let scoreSum = 0, blindSum = 0, validSubs = 0;
        let totApp = 0, totUnk = 0, totNa = 0, totAll = 0;
        const subList = [];
        for (const s in subs) {
          const b = subs[s];
          const app = b.total - b.na;
          const subScore = app > 0 ? (b.yes / app) * 100 : null;
          const subBlind = app > 0 ? (b.unknown / app) * 100 : 0;
          subList.push({ name:s, score: subScore, blindspot: subBlind, naAll: app === 0,
                         total:b.total, yes:b.yes, no:b.no, unknown:b.unknown, na:b.na });
          if (app > 0) { scoreSum += subScore; blindSum += subBlind; validSubs++; }
          totApp += app; totUnk += b.unknown; totNa += b.na; totAll += b.total;
        }
        catRes[cat] = {
          score: validSubs > 0 ? scoreSum / validSubs : null,
          blindspot: validSubs > 0 ? blindSum / validSubs : 0,
          allNa: validSubs === 0,
          totalApplicable: totApp, totalUnknown: totUnk, totalNa: totNa, totalAll: totAll,
          subs: subList, layer: scaleStructure[cat].layer, icon: scaleStructure[cat].icon,
        };
      }
      perPartner.push(catRes);
    }
    return perPartner;
  }
  function zoneOf(score, blindspot) {
    if (blindspot > 25) return 'blind';
    if (score === null) return 'na';
    if (score < 50) return 'red';
    if (score < 80) return 'amber';
    return 'green';
  }
  function zoneLabel(z) { return z === 'red' ? 'красная' : z === 'amber' ? 'жёлтая' : z === 'green' ? 'зелёная' : z === 'blind' ? 'слепое пятно' : 'н/п'; }
  function zonePill(score, blindspot) {
    const z = zoneOf(score, blindspot);
    return '<span class="zone-pill zone-' + (z === 'blind' ? 'blind' : z) + '">' + zoneLabel(z) + '</span>';
  }
  function barColor(score, blindspot) {
    if (blindspot > 25) return 'var(--amber)';
    if (score === null) return 'var(--hairline)';
    if (score < 50) return 'var(--red)';
    if (score < 80) return 'var(--amber)';
    return 'var(--green)';
  }
  function fmtPct(score) { return score === null ? 'н/п' : Math.round(score) + '%'; }

