    content.push({
      ul: [
        'Шкала ответов: «Да» / «Нет» / «Не уверен(а)» / «Не релевантно». Score = % «Да» от применимых (total − na). Blindspot = % «Не уверен(а)» от применимых.',
        'Зоны по score: красная менее 50%; жёлтая 50–79%; зелёная 80% и выше.',
        'Если blindspot > 25% — категория помечена как «слепое пятно»: score нерепрезентативен.',
        '12 категорий разнесены по слоям: Фундамент, Архитектура, Надстройка.',
        'При нескольких партнёрах в сводной матрице показан результат каждого партнёра отдельно.',
      ],
      style: 'normal', fontSize: 9, margin:[0,0,0,16]
    });

    // Сводная матрица: 12 категорий × N партнёров
    content.push({ text: 'СВОДНАЯ МАТРИЦА', style:'eyebrow', margin:[0,8,0,6] });
    const headerRow = [{ text:'Категория', bold:true, fontSize:10 }, { text:'Слой', bold:true, fontSize:10 }];
    partnerNames.forEach(n => headerRow.push({ text: n, bold:true, fontSize:10, alignment:'center' }));
    const mrows = [headerRow];
    for (const cat in results[0]) {
      const row = [{ text: cat, fontSize:9 }, { text: results[0][cat].layer, fontSize:9 }];
      for (let pi = 0; pi < partnerCount; pi++) {
        const r = results[pi][cat];
        row.push({ text: fmt(r.score) + '\n' + zName(r.score, r.blindspot), fontSize:9, alignment:'center', fillColor: zoneFill(r.score, r.blindspot) });
      }
      mrows.push(row);
    }
    content.push({ table: { widths: ['*', 75].concat(partnerNames.map(() => 65)), body: mrows }, layout: 'lightHorizontalLines', margin:[0,0,0,16] });

    // Расхождения
    if (partnerCount > 1) {
      content.push({ text: 'РАСХОЖДЕНИЯ МЕЖДУ ПАРТНЁРАМИ', style:'eyebrow', margin:[0,12,0,4] });
      const divs = [];
      for (const cat in results[0]) {
        const scores = results.map(r => r[cat].score);
        const valid = scores.filter(s => s !== null);
        if (valid.length < 2) continue;
        const gap = Math.max(...valid) - Math.min(...valid);
        if (gap >= 25) divs.push({ cat, scores, gap });
      }
      divs.sort((a,b) => b.gap - a.gap);
      if (!divs.length) {
        content.push({ text: 'Разрыв между партнёрами по всем категориям < 25 п.п.', style:'normal', italics:true, margin:[0,0,0,12] });
      } else {
        const drows = [[{ text:'Категория', bold:true, fontSize:10 }, { text:'Разрыв', bold:true, fontSize:10, alignment:'right' }]
          .concat(partnerNames.map(n => ({ text:n, bold:true, fontSize:10, alignment:'right' })))];
        divs.forEach(d => {
          const r = [{ text:d.cat, fontSize:9 }, { text: Math.round(d.gap) + ' п.п.', fontSize:9, alignment:'right', bold:true, color:'#9f1239' }];
          d.scores.forEach(s => r.push({ text: fmt(s), fontSize:9, alignment:'right' }));
          drows.push(r);
        });
        content.push({ table: { widths:['*', 60].concat(partnerNames.map(()=>50)), body: drows }, layout: 'lightHorizontalLines', margin:[0,0,0,16] });
      }
    }

    // Разбивка подкатегорий по партнёрам
    content.push({ text: 'РАЗБИВКА ПО ПОДКАТЕГОРИЯМ', style:'eyebrow', pageBreak:'before', margin:[0,10,0,4] });
    for (let pi = 0; pi < partnerCount; pi++) {
      content.push({ text: partnerNames[pi], style:'partnerSection', margin:[0,12,0,6] });
      for (const cat in results[pi]) {
        const r = results[pi][cat];
        content.push({ text: cat + ' · ' + r.layer + ' — ' + fmt(r.score) + ' · ' + zName(r.score, r.blindspot), bold:true, fontSize:10, margin:[0,6,0,4] });
        const subRows = [[
          { text:'Подкатегория', bold:true, fontSize:9 },
          { text:'Да', bold:true, fontSize:9, alignment:'right' },
          { text:'Нет', bold:true, fontSize:9, alignment:'right' },
          { text:'?', bold:true, fontSize:9, alignment:'right' },
          { text:'н/р', bold:true, fontSize:9, alignment:'right' },
          { text:'Σ', bold:true, fontSize:9, alignment:'right' },
          { text:'Score', bold:true, fontSize:9, alignment:'right' },
        ]];
        r.subs.forEach(s => {
          subRows.push([
            { text: s.name, fontSize:9 },
            { text: s.yes, alignment:'right', fontSize:9 },
            { text: s.no, alignment:'right', fontSize:9 },
            { text: s.unknown, alignment:'right', fontSize:9 },
            { text: s.na, alignment:'right', fontSize:9 },
            { text: s.total, alignment:'right', fontSize:9, color:'#78716c' },
            { text: s.score === null ? 'н/п' : Math.round(s.score) + '%', alignment:'right', fontSize:9, bold: s.score !== null && s.score < 50, color: s.score !== null && s.score < 50 ? '#9f1239' : '#282828' },
          ]);
        });
        content.push({ table: { widths: ['*',30,30,30,30,30,50], body: subRows }, layout: 'lightHorizontalLines', margin:[0,0,0,8] });
      }
    }

    // Сырые ответы
    content.push({ text: 'СЫРЫЕ ОТВЕТЫ', style:'eyebrow', pageBreak:'before', margin:[0,10,0,4] });
    content.push({ text: 'Все 121 утверждение × ' + partnerCount + ' партнёр(ов).', style:'normal', italics:true, fontSize:9, margin:[0,0,0,8] });
    const rawHeader = [
      { text:'#', bold:true, fontSize:8 },
      { text:'Категория · подкатегория', bold:true, fontSize:8 },
      { text:'Утверждение', bold:true, fontSize:8 },
    ];
    partnerNames.forEach(n => rawHeader.push({ text:n, bold:true, fontSize:8, alignment:'center' }));
    const rawRows = [rawHeader];
    const partnerColW = partnerCount >= 4 ? 24 : partnerCount === 3 ? 28 : 32;
    qMetaByIdx.forEach((meta, idx) => {
      const qid = 'q' + (idx + 1);
      const row = [
        { text: String(idx + 1), fontSize:7 },
        { text: meta.scale + ' · ' + meta.subscale, fontSize:7 },
        { text: questionTexts[qid] || '', fontSize:7 },
      ];
      for (let pi = 0; pi < partnerCount; pi++) {
        const a = (answers[qid] && answers[qid][pi]) || '—';
        const txt = a === 'yes' ? 'Да' : a === 'no' ? 'Нет' : a === 'unknown' ? '?' : a === 'na' ? 'н/р' : '—';
        const color = a === 'no' ? '#9f1239' : a === 'unknown' ? '#a16207' : a === 'na' ? '#78716c' : '#282828';
        row.push({ text: txt, alignment:'center', fontSize:8, color: color, bold: a === 'no' });
      }
      rawRows.push(row);
    });
    content.push({ table: { headerRows:1, widths: [12, 80, '*'].concat(partnerNames.map(()=>partnerColW)), body: rawRows }, layout: 'lightHorizontalLines', fontSize: 8 });

    const adminDocDef = {
      pageSize: 'A4', pageMargins: [40, 40, 40, 50],
      defaultStyle: { font:'Roboto', fontSize:10, color:'#282828', lineHeight:1.35 },
      styles: {
        eyebrow: { fontSize:9, color:'#876444', characterSpacing:1.2, bold:true },
        coverTitle: { fontSize:20, bold:true, color:'#282828' },
        normal: { fontSize:10, color:'#282828' },
        th: { fontSize:9, color:'#78716c', bold:true },
        partnerSection: { fontSize:14, bold:true, color:'#876444' },
        partnerLine: { fontSize:12, bold:true, color:'#876444' },
        footerText: { fontSize:8, color:'#78716c', alignment:'center' },
      },
      footer: function(p, total) {
        return { stack:[
          { text: 'ТЕХНИЧЕСКИЙ ОТЧЁТ · респондент: ' + userName + ' · ' + dateStr, style:'footerText' },
          { text: 'Академия Партнёрства · служебный документ · стр. ' + p + ' / ' + total, style:'footerText' },
        ], margin:[40, 10, 40, 0]};
      },
      content
    };

    return new Promise((resolve) => {
      pdfMake.createPdf(adminDocDef).getDataUrl(async dataUrl => {
        try {
          await fetch(SCRIPT_URL, { method:'POST', body: JSON.stringify({
            pdfData: dataUrl,
            userName: 'ТЕХ_Новое_партнёрство_' + userName + '_' + new Date().toISOString().slice(0,10),
            adminReport: true, respondentEmail: userEmail || null, respondentName: userName,
            testType: 'new_partnership'
          }) });
        } catch (e) { console.error('admin send error:', e); }
        resolve();
      });
    });
  }

  init();
})();
